# =============================================================================
# Crypto Trade Hub - Production Environment Configuration
# =============================================================================
#
# IMPORTANT SECURITY NOTE:
# - Never commit .env.production to version control
# - Use strong, randomly generated passwords (use: openssl rand -base64 32)
# - Change ALL default values before deploying to production
# - Use environment variable secrets management in cloud deployments
#
# Setup:
#   1. Copy this file to .env.production
#   2. Replace all placeholder values with production values
#   3. Generate strong passwords using: openssl rand -base64 32
#   4. Keep .env.production secure with proper file permissions (chmod 600)
#
# =============================================================================

# ==================== MONGO DB CONFIGURATION ====================
# MongoDB admin credentials (used for docker-compose initialization)
MONGO_ROOT_USER=admin
MONGO_ROOT_PASSWORD=changeme-with-strong-password-32-chars-min

# MongoDB database name
MONGO_DBNAME=crypto_trade_hub

# MongoDB URL (constructed in docker-compose, but can be overridden)
# Full format: mongodb://username:password@host:port/database?authSource=admin
# Don't include this unless using external MongoDB
# MONGODB_URL=mongodb://admin:password@mongodb:27017/crypto_trade_hub?authSource=admin

# ==================== REDIS CONFIGURATION ====================
# Redis password (optional but recommended)
REDIS_PASSWORD=changeme-with-strong-password

# Redis URL (usually auto-constructed in docker-compose)
# Format: redis://[:password]@host:port/database
# REDIS_URL=redis://redis:6379/0
# REDIS_CACHE_URL=redis://redis:6379/1

# ==================== FASTAPI / BACKEND CONFIGURATION ====================
# Environment
ENVIRONMENT=production
DEBUG=false

# JWT Secrets (generate with: openssl rand -base64 32)
JWT_SECRET_KEY=your-secret-key-change-this-to-random-32-char-min-string

# Token expiration times (in minutes)
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_MINUTES=10080  # 7 days

# ==================== GOOGLE OAUTH (Optional) ====================
# Get credentials from: https://console.cloud.google.com/
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# ==================== CORS & SECURITY ====================
# Allowed hosts for CORS
ALLOWED_HOSTS=localhost,yourdomain.com,www.yourdomain.com

# CORS origins (JSON array)
BACKEND_CORS_ORIGINS=["http://localhost:3000", "https://yourdomain.com", "https://www.yourdomain.com"]

# ==================== LOGGING ====================
# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=info

# Should logs be formatted as JSON (for log aggregation services)
LOG_FORMAT=json

# ==================== SMTP / EMAIL (Optional) ====================
# For sending transactional emails (password reset, 2FA, etc)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-app-specific-password
SMTP_FROM_EMAIL=noreply@crypto-trade-hub.com
SMTP_FROM_NAME="Crypto Trade Hub"

# ==================== EXTERNAL APIs ====================
# KuCoin API (users provide via web interface, this is optional/backup)
KUCOIN_API_KEY=
KUCOIN_API_SECRET=

# Binance API (users provide via web interface, this is optional/backup)
BINANCE_API_KEY=
BINANCE_API_SECRET=

# ==================== SENTRY / ERROR TRACKING (Optional) ====================
# For error tracking and monitoring in production
SENTRY_DSN=

# ==================== NOTIFICATION WEBHOOKS - CRITICAL FOR OPERATIONS ====================
# Discord webhook for error alerts and bot notifications
# Get from: https://discord.com/developers/applications -> Webhooks
# Format: https://discord.com/api/webhooks/CHANNEL_ID/TOKEN
DISCORD_WEBHOOK_URL=

# Slack webhook for error alerts and bot notifications
# Get from: https://api.slack.com/apps -> Incoming Webhooks
# Format: https://hooks.slack.com/services/YOUR/WEBHOOK/URL
SLACK_WEBHOOK_URL=

# Enable webhook notifications (true/false)
ENABLE_ERROR_NOTIFICATIONS=true

# API Monitor Configuration
# Check API keys and balances every N minutes
API_MONITOR_CHECK_INTERVAL_MINUTES=30

# Minimum balance required (in USD) to keep bot running
API_MONITOR_MINIMUM_BALANCE_USD=50.0

# Maximum retry attempts before auto-disabling bot
API_MONITOR_MAX_RETRIES=3

# ==================== STRIPE / PAYMENTS (Optional) ====================
# For handling subscription plans and payments
STRIPE_API_KEY=
STRIPE_WEBHOOK_SECRET=

# ==================== AWS / CLOUD STORAGE (Optional) ====================
# For storing bot logs, backups, etc. in S3
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=crypto-trade-hub-backups
AWS_S3_REGION=us-east-1

# ==================== DATABASE BACKUP ====================
# Enable automatic backups (before enabling, ensure S3 is configured)
ENABLE_BACKUPS=true
BACKUP_SCHEDULE="0 2 * * *"  # Daily at 2 AM
BACKUP_RETENTION_DAYS=30

# ==================== SECURITY & RATE LIMITING ====================
# Number of login attempts before lockout
LOGIN_MAX_ATTEMPTS=5

# Lockout duration in minutes
LOGIN_LOCKOUT_DURATION=15

# API rate limiting (requests per minute)
API_RATE_LIMIT_PER_MINUTE=1000

# ==================== TRADING BOT CONFIGURATION ====================
# Enable/disable bot trading
ENABLE_BOTS=true

# Maximum concurrent bots per user (singleton rule)
MAX_CONCURRENT_BOTS_PER_USER=1

# Activation credits system
ACTIVATION_CREDITS_ENABLED=true

# Default credits by plan
STARTER_CREDITS=1
PRO_CREDITS=5
PREMIUM_CREDITS=15
ENTERPRISE_CREDITS=100

# ==================== MONITORING & HEALTH ====================
# Health check endpoint response
HEALTH_CHECK_ENABLED=true

# Prometheus metrics endpoint (for monitoring)
PROMETHEUS_ENABLED=false
PROMETHEUS_PORT=9090

# ==================== TIMEZONE ====================
# Server timezone
TZ=UTC

# ==================== DEPLOYMENT SPECIFIC ====================
# Domain name (used in emails, redirects, etc)
DOMAIN_NAME=yourdomain.com

# Frontend URL (used in emails, redirects)
FRONTEND_URL=https://yourdomain.com

# API Base URL (used in frontend)
API_BASE_URL=https://yourdomain.com/api/v1

# ==================== DOCKER COMPOSE ====================
# Docker Compose project name (used for container names)
COMPOSE_PROJECT_NAME=crypto-trade

# =============================================================================
# PRODUCTION DEPLOYMENT CHECKLIST
# =============================================================================
#
# Before deploying to production, ensure:
#
# [ ] All "changeme-" passwords are replaced with strong random values
# [ ] JWT_SECRET_KEY is at least 32 characters and cryptographically random
# [ ] GOOGLE credentials are properly configured (or GOOGLE_*)={empty}
# [ ] DOMAIN_NAME matches your actual domain
# [ ] SSL certificates are in place (./certs/cert.pem, ./certs/key.pem)
# [ ] ALLOWED_HOSTS and BACKEND_CORS_ORIGINS are correct
# [ ] Email (SMTP_*) is configured for transactional emails
# [ ] Backups are configured (AWS_*) and ENABLE_BACKUPS=true
# [ ] Sentry or another error tracking service is configured
# [ ] All external API keys are set (KuCoin, Binance, etc)
# [ ] Server has sufficient disk space for MongoDB/Redis persistence
# [ ] Firewall rules are configured (only 80/443 exposed)
# [ ] SSL/TLS certificates are valid and auto-renewal is configured
# [ ] Database backups are tested and verified
# [ ] Monitoring and alerting are configured
# [ ] Log aggregation service is configured (ELK, Datadog, etc)
# [ ] Rate limiting and DDoS protection are in place
# [ ] Database replica set is initialized
#
# =============================================================================
