# ============================================================
# 🚀 CRYPTO TRADE HUB - Backend Environment Variables
# ============================================================
# Copy this file to .env and fill in the values
# NEVER commit .env with real secrets!

# ============== DATABASE ==============
# MongoDB Atlas (production) - Get from https://cloud.mongodb.com/
DATABASE_URL=mongodb+srv://username:password@cluster.mongodb.net/crypto_trade_hub?retryWrites=true&w=majority
DATABASE_NAME=crypto_trade_hub

# For local MongoDB (development):
# DATABASE_URL=mongodb://localhost:27017
# DATABASE_NAME=crypto_trade_hub_dev

# Offline mode (uses SQLite for persistence)
OFFLINE_MODE=false

# ============== SECURITY ==============
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=CHANGE_ME_TO_A_64_CHARACTER_RANDOM_STRING_IN_PRODUCTION

# JWT Configuration
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_MINUTES=10080
ALGORITHM=HS256

# 🔐 Encryption Key for API Credentials
# ⚠️ CRÍTICO: Faça BACKUP FÍSICO desta chave (papel, cofre)!
# Se você perder esta chave, TODAS as API Keys dos usuários serão PERDIDAS!
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=GENERATE_A_NEW_FERNET_KEY_HERE

# ============== CORS ==============
# Comma-separated allowed origins for frontend
ALLOWED_ORIGINS=http://localhost:8080,http://localhost:8081,http://localhost:5173,http://127.0.0.1:8080,http://127.0.0.1:8081,http://127.0.0.1:5173

# ============== API KEYS (AI Services) ==============
# Google Cloud Vision API (for chart analysis)
GOOGLE_API_KEY=your_google_api_key_here

# Groq AI API (for AI analysis)
GROQ_API_KEY=your_groq_api_key_here

# ============== FEATURES ==============
# Enable/disable features
ENABLE_BOTS=true
ENABLE_NEWS=true
ENABLE_ANALYTICS=true

# ============== SCHEDULER ==============
# Intervals in seconds for background tasks
SCHEDULER_BOTS_INTERVAL=5
SCHEDULER_NEWS_INTERVAL=30
SCHEDULER_ANALYTICS_INTERVAL=60

# ============== SIMULATION ==============
# Initial balance for simulated trading
INITIAL_BALANCE=10000

# ============== TRANSLATION ==============
TRANSLATION_ENABLED=true
TRANSLATION_TARGET=pt

# ============== APP MODE ==============
# Options: dev, staging, prod
APP_MODE=dev

# ============== EXCHANGE APIs (Optional) ==============
# KuCoin API (for live trading)
# Get from https://www.kucoin.com/account/api
# KUCOIN_API_KEY=your_kucoin_api_key
# KUCOIN_API_SECRET=your_kucoin_api_secret
# KUCOIN_API_PASSPHRASE=your_kucoin_passphrase
# KUCOIN_SANDBOX=true

# Binance API (for live trading)
# Get from https://www.binance.com/en/my/settings/api-management
# BINANCE_API_KEY=your_binance_api_key
# BINANCE_API_SECRET=your_binance_api_secret
# BINANCE_TESTNET=true

# ============== GOOGLE OAUTH ==============
# Get from https://console.cloud.google.com/
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret

# ============== GOOGLE SHEETS (Login Tracking) ==============
GOOGLE_SHEETS_ENABLED=false
GOOGLE_SHEETS_CREDENTIALS_FILE=credentials.json
GOOGLE_SHEETS_SPREADSHEET_ID=your_spreadsheet_id

# ============== LICENSING (Future) ==============
LICENSING_URL=
LICENSING_TIMEOUT=5
LICENSING_CACHE_TTL=300

# ============== APPLICATION MODE ==============
# dev, staging, prod (affects logging verbosity)
APP_MODE=dev

# ============================================================================
# 💳 DOC-07: Perfect Pay — Gateway de Pagamento e Licenciamento
# ============================================================================

# Token da API Perfect Pay (gerado em Ferramentas > API no painel Perfect Pay)
PERFECT_PAY_API_KEY=

# Segredo compartilhado para validar HMAC-SHA256 dos Postbacks
PERFECT_PAY_POSTBACK_SECRET=

# Mapeamento product_token → plano em JSON
# Exemplo: '{"tok_basic":"basic","tok_pro":"pro","tok_enterprise":"enterprise"}'
PERFECT_PAY_PLAN_MAP={}

# ============================================================================
# 🔐 DOC-07: Licenciamento — Chave de Criptografia de Licenças
# ============================================================================

# Chave Fernet para assinar/verificar licenças (AES-256)
# Gere com: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# ⚠️ CRÍTICO: Nunca altere esta chave em produção sem migrar as licenças existentes!
LICENSING_FERNET_KEY=

# ============================================================================
# 📈 DOC-08: Marketplace de Estratégias
# ============================================================================

# Chave Fernet para cifrar código-fonte das estratégias em repouso (AES-256)
# Gere com: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# ⚠️ CRÍTICO: Faça backup físico desta chave — estratégias serão ilegíveis sem ela!
STRATEGY_ENCRYPTION_KEY=GENERATE_A_NEW_FERNET_KEY_HERE

# Percentual da plataforma no revenue share (0.0 a 1.0)
# Criador recebe: 1 - MARKETPLACE_PLATFORM_TAKE_RATE
# Default: 0.30 (plataforma 30%, criador 70%)
MARKETPLACE_PLATFORM_TAKE_RATE=0.30

# ============================================================================
# 🛡️ DOC-10: Rate Limiting (por userId e IP)
# ============================================================================

# Máximo de requisições por janela para usuários autenticados
RATE_LIMIT_USER=100

# Máximo de requisições por janela para IPs anônimos
RATE_LIMIT_IP=30

# Tamanho da janela de rate limiting em segundos
RATE_LIMIT_WINDOW_SEC=60

# ============================================================================
# ✨ FASE 2 - Security & FastAPI Integration (NEW)
# ============================================================================

# 🔐 Credential Encryption Key (REQUIRED for FASE 2)
# Fernet symmetric encryption for user API credentials
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# ⚠️ CRÍTICO: Keep this secure and make backups!
CREDENTIAL_ENCRYPTION_KEY=GENERATE_A_NEW_FERNET_KEY_HERE

# ============================================================================
# Trading Risk Management (FASE 2)
# ============================================================================

# Maximum position size in USD
MAX_POSITION_SIZE_USD=100000

# Maximum loss per single trade in USD
MAX_LOSS_PER_TRADE_USD=1000

# Maximum cumulative loss per day in USD
MAX_DAILY_LOSS_USD=5000

# Maximum allowed leverage
MAX_LEVERAGE=10.0

# Maximum number of open positions simultaneously
MAX_OPEN_POSITIONS=10

# ============================================================================
# WebSocket Configuration (FASE 2)
# ============================================================================

# Heartbeat timeout in seconds (detect stale connections)
WS_HEARTBEAT_TIMEOUT=30

# Maximum reconnection attempts before giving up
WS_MAX_RECONNECT_ATTEMPTS=10

# ============================================================================
# Order Execution Configuration (FASE 2)
# ============================================================================

# Maximum number of retry attempts for failed orders
ORDER_MAX_RETRIES=3

# Base backoff time in seconds for exponential backoff
ORDER_BACKOFF_BASE=1

# ============================================================================
# Logging Configuration (FASE 2)
# ============================================================================

# Sanitize logs to remove API keys and secrets (RECOMMENDED)
SANITIZE_LOGS=true

# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

