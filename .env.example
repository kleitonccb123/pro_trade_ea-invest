# ============================================================
# 🚀 CRYPTO TRADE HUB - Frontend Environment Variables
# ============================================================
# Copy this file to .env and fill in the values

# Backend API URL (where FastAPI is running)
VITE_API_BASE_URL=http://localhost:8001

# ============== OPTIONAL ==============
# These are loaded in the root .env and shared with backend

# MongoDB Connection (for reference)
# DATABASE_URL=mongodb+srv://user:pass@cluster.mongodb.net/db

# Offline Mode (use local SQLite instead of MongoDB)
# OFFLINE_MODE=false

# Security Keys
# SECRET_KEY=your_secret_key_here
# ENCRYPTION_KEY=your_fernet_key_here

# Google OAuth Client ID (for Google Sign-In button)
# VITE_GOOGLE_CLIENT_ID=your_client_id.apps.googleusercontent.com

# P3-10: Crisp customer support chat widget (optional)
# Sign up at https://crisp.chat, create a website, and paste the Website ID here
# VITE_CRISP_WEBSITE_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# KuCoin WebSocket URL (chart uses backend /kucoin/ws-token for proper token-based WS)
# Only needed if you want to override the default production endpoint
# VITE_KUCOIN_WS_URL=wss://ws-api-spot.kucoin.com
