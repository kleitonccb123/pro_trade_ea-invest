# ============================================================
# 🚀 CRYPTO TRADE HUB — Template Completo de Produção
# ============================================================
# INSTRUÇÕES:
#   1. cp .env.prod.example .env.prod
#   2. Preencher TODOS os campos marcados como OBRIGATÓRIO
#   3. NUNCA versionar .env.prod no git
#   4. docker-compose -f docker-compose.prod.yml --env-file .env.prod up -d
#
# Geração de chaves seguras:
#   JWT_SECRET_KEY : python -c "import secrets; print(secrets.token_hex(32))"
#   ENCRYPTION_KEY : python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
#   MONGO/REDIS pw : python -c "import secrets; print(secrets.token_urlsafe(32))"
# ============================================================

# ── Modo de operação ────────────────────────────────────
APP_MODE=prod
ENVIRONMENT=production
DEBUG=false

# ── Segurança (OBRIGATÓRIO) ───────────────────────────
# ATENÇÃO: Guardar OFFLINE (KeePass/Vault). Perder ENCRYPTION_KEY =
# todas as chaves de exchange dos usuários tornam-se IRRECUPERÁVEIS.
JWT_SECRET_KEY=                          # OBRIGATÓRIO
ENCRYPTION_KEY=                          # OBRIGATÓRIO (Fernet base64)
FERNET_KEY=                              # OBRIGATÓRIO (mesmo valor que ENCRYPTION_KEY)
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_MINUTES=10080

# ── Banco de dados (OBRIGATÓRIO) ───────────────────────
MONGO_ROOT_USER=admin
MONGO_ROOT_PASSWORD=                     # OBRIGATÓRIO
MONGO_DBNAME=crypto_trade_hub
MONGODB_URL=mongodb://admin:${MONGO_ROOT_PASSWORD}@mongodb:27017/crypto_trade_hub?authSource=admin
DATABASE_URL=mongodb://admin:${MONGO_ROOT_PASSWORD}@mongodb:27017/crypto_trade_hub?authSource=admin

# ── Redis (OBRIGATÓRIO) ─────────────────────────────────
REDIS_PASSWORD=                          # OBRIGATÓRIO
REDIS_URL=redis://:${REDIS_PASSWORD}@redis:6379/0
REDIS_CACHE_URL=redis://:${REDIS_PASSWORD}@redis:6379/1

# ── CORS / Domínio (OBRIGATÓRIO) ───────────────────────
ALLOWED_ORIGINS=https://seudominio.com.br,https://www.seudominio.com.br
ALLOWED_HOSTS=seudominio.com.br,www.seudominio.com.br
BACKEND_CORS_ORIGINS=["https://seudominio.com.br","https://www.seudominio.com.br"]

# ── Google OAuth (OBRIGATÓRIO para login Google) ───────────
# Obter em: console.cloud.google.com → APIs & Services → Credentials
# Registrar no Google Console: https://seudominio.com.br/api/auth/google/callback
GOOGLE_CLIENT_ID=                        # OBRIGATÓRIO
GOOGLE_CLIENT_SECRET=                    # OBRIGATÓRIO
GOOGLE_REDIRECT_URI=https://seudominio.com.br/api/auth/google/callback
FRONTEND_REDIRECT_URI=https://seudominio.com.br/auth/callback

# ── SMTP / E-mail (RECOMENDADO) ──────────────────────────
# Sem isso: OTPs e reset de senha não chegam ao usuário.
# Gmail: usar App Password (myaccount.google.com → Security → App passwords)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@seudominio.com.br

# ── Perfect Pay (OBRIGATÓRIO para receber pagamentos) ────────
PERFECT_PAY_API_KEY=
PERFECT_PAY_POSTBACK_SECRET=
PERFECT_PAY_PLAN_MAP={"plano_mensal": "PRO", "plano_anual": "PRO+"}

# ── KuCoin — Engine de Trading ────────────────────────────
# ATENÇÃO: true=sandbox, false=dinheiro real. Testar com true primeiro!
KUCOIN_SANDBOX=true
KUCOIN_API_KEY=
KUCOIN_API_SECRET=
KUCOIN_API_PASSPHRASE=
INITIAL_BALANCE=10000
MAX_BOTS_PER_ENGINE=50

# ── Frontend (baked no build Docker) ──────────────────────
VITE_API_BASE_URL=https://seudominio.com.br/api
VITE_API_BASE=https://seudominio.com.br/api
VITE_GOOGLE_CLIENT_ID=                   # Mesmo valor de GOOGLE_CLIENT_ID

# ── Monitoramento (opcional) ─────────────────────────────
SENTRY_DSN=
LOG_LEVEL=INFO

# ── Recursos opcionais ──────────────────────────────────
VITE_CRISP_WEBSITE_ID=                   # Chat de suporte (crisp.chat)
GROQ_API_KEY=                            # IA de análise de mercado
GOOGLE_API_KEY=                          # Gemini
VAPID_PRIVATE_KEY=                       # Web push
VAPID_PUBLIC_KEY=
VAPID_CONTACT=mailto:admin@seudominio.com.br
# IMAGE_TAG=latest

# ── Core ─────────────────────────────────────────────────────
ENVIRONMENT=production
DEBUG=false

# JWT — minimum 32 random characters
JWT_SECRET_KEY=change-me-minimum-32-chars-random-string-here
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_MINUTES=10080

# Fernet encryption key for KuCoin credentials (base64, 32 bytes)
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FERNET_KEY=your-base64-encoded-32-byte-fernet-key-here

# ── Database ──────────────────────────────────────────────────
# Single-node (development / small production):
MONGODB_URL=mongodb://admin:changeme@mongodb:27017/crypto_trade_hub?authSource=admin
MONGO_DBNAME=crypto_trade_hub
MONGO_ROOT_USER=admin
MONGO_ROOT_PASSWORD=changeme

# Replica Set (production HA):
# MONGODB_URL=mongodb://user:pass@mongo1:27017,mongo2:27017,mongo3:27017/crypto_hub?replicaSet=rs0&authSource=admin

# ── Redis ─────────────────────────────────────────────────────
REDIS_URL=redis://:your-redis-password@redis:6379/0
REDIS_CACHE_URL=redis://:your-redis-password@redis:6379/1

# ── KuCoin ───────────────────────────────────────────────────
KUCOIN_SANDBOX=false
# Per-user credentials are stored encrypted in MongoDB — no global keys here.

# ── CORS / Hosts ──────────────────────────────────────────────
ALLOWED_HOSTS=yourdomain.com,www.yourdomain.com
BACKEND_CORS_ORIGINS=["https://yourdomain.com","https://www.yourdomain.com"]

# ── Google OAuth (optional) ───────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── Email / Notifications ─────────────────────────────────────
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USER=apikey
SMTP_PASSWORD=your-sendgrid-api-key

# ── Telegram Alerts (DOC-08 TelegramAlerter) ─────────────────
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
TELEGRAM_CHAT_ID=your-telegram-chat-id

# ── Sentry Error Tracking ─────────────────────────────────────
SENTRY_DSN=https://xxxxx@sentry.io/xxxxx

# ── Monitoring ────────────────────────────────────────────────
GRAFANA_PASSWORD=secure-grafana-admin-password

# ── Engine Scaling ────────────────────────────────────────────
MAX_BOTS_PER_ENGINE=50
LOG_LEVEL=INFO

# ── Image Tag (used by deploy_zero_downtime.sh) ───────────────
# IMAGE_TAG=latest
